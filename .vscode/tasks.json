{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "g++",
            "args": [
                "main.cpp",
                "graph.cpp",
                "bfs.cpp",
                "dijkstra.cpp",
                "fileloader.cpp",
                "-o",
                "pathfinder",
                ";",
                "./pathfinder"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "shell": {
                "executable": "cmd.exe",
                "args": ["/d", "/c"]
            }
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "g++",
            "args": [
                "tests.cpp",
                "graph.cpp",
                "bfs.cpp",
                "dijkstra.cpp",
                "fileloader.cpp",
                "-o",
                "tests",
                ";",
                "./tests"
            ],
            "shell": {
                "executable": "cmd.exe",
                "args": ["/d", "/c"]
            }
        }
    ]
}